@model Incubadora.Models.FazendaViewModel

<h2>Cadastro de Fazenda</h2>

<form asp-action="Save" method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>Nome da Fazenda</label>
        <input asp-for="NomeFazenda" class="form-control" />
    </div>

    <div>
        <label>CEP</label>
        <input asp-for="CEP" class="form-control" />
    </div>

    <div>
        <label>Rua</label>
        <input asp-for="RuaFazenda" class="form-control" />
    </div>

    <div>
        <label>Bairro</label>
        <input asp-for="BairroFazenda" class="form-control" />
    </div>

    <div>
        <label>Cidade</label>
        <input asp-for="CidadeFazenda" class="form-control" />
    </div>

    <div>
        <label>Estado</label>
        <input asp-for="EstadoFazenda" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Salvar</button>
    <a href="/Fazenda/Index" class="btn btn-secondary">Voltar</a>
</form>
