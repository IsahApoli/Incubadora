@model List<NidusFront.Models.AnimalViewModel>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Meus Animais";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    string perfilLogado = Context.Session.GetString("UsuarioPerfil") ?? "";
    bool isAdmin = perfilLogado.ToLower() == "admin";
    int idUsuarioLogado = Convert.ToInt32(Context.Session.GetString("UsuarioId") ?? "0");
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="titulo-pagina m-0"><i class="bi bi-clipboard2-data-fill me-2"></i> PRESETS DE ANIMAIS</h2>
    </div>

    <p class="text-white opacity-75 mb-3">Gerencie as variáveis de incubação. Os animais listados aqui aparecerão nas opções da sua incubadora.</p>

    <div class="d-flex gap-2 mb-4 justify-content-start overflow-auto py-2" id="blocoFiltros">
        <button class="btn btn-filtro active shadow-sm" data-filtro="todos"><i class="bi bi-grid-fill me-1"></i> Todos os Animais</button>
        <button class="btn btn-filtro shadow-sm" data-filtro="padrao"><i class="bi bi-lock-fill me-1 text-secondary"></i> Padrão do Sistema</button>
        <button class="btn btn-filtro shadow-sm" data-filtro="customizado"><i class="bi bi-person-fill me-1 text-success"></i> Meus Animais</button>
    </div>

    <div class="row g-4" id="gridAnimais">

        @foreach (var animal in Model)
        {
            bool isPadrao = animal.IdUsuario == null;

            <div class="col-12 col-md-6 col-lg-4 item-animal @(!isPadrao ? "cliente-only" : "")" data-tipo="@(isPadrao ? "padrao" : "customizado")">
                <div class="animal-card h-100 @(isPadrao ? "border-padrao" : "border-customizado")">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="d-flex align-items-center">
                            @if (!string.IsNullOrEmpty(animal.ImagemBase64))
                            {
                                <img src="data:image/jpeg;base64,@animal.ImagemBase64" class="rounded-circle me-2 border border-success" style="width: 45px; height: 45px; object-fit: cover;" />
                            }
                            <h3 class="fw-bold mb-0 @(!isPadrao ? "text-success" : "")">@animal.NomeEspecie</h3>
                        </div>

                        @if (isPadrao)
                        {
                            <span class="badge bg-secondary opacity-75"><i class="bi bi-lock-fill me-1"></i> Padrão do Sistema</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Meu Animal</span>
                        }
                    </div>

                    <div class="variaveis-grid mb-4">
                        <div class="var-item"><small>Temp:</small> <b>@animal.TempMin a @animal.TempMax°C</b></div>
                        <div class="var-item"><small>Umid:</small> <b>@animal.UmidMin a @animal.UmidMax%</b></div>
                        <div class="var-item"><small>Luz:</small> <b>@animal.LuzMin a @animal.LuzMax Lxs</b></div>
                    </div>

                    @{
                        bool podeEditar = isAdmin || (!isPadrao && animal.IdUsuario == idUsuarioLogado);
                    }
                    @if (podeEditar)
                    {
                        <div class="mt-auto border-top pt-3 border-secondary border-opacity-50">
                            @if (isPadrao)
                            {
                                <a href="/Animal/EditarAnimal/@animal.Id" class="btn btn-sm btn-outline-warning w-100"><i class="bi bi-pencil-square me-1"></i> Editar Padrão Global</a>
                            }
                            else
                            {
                                <div class="d-flex gap-2">
                                    <a href="/Animal/EditarAnimal/@animal.Id" class="btn btn-sm btn-outline-warning flex-grow-1"><i class="bi bi-pencil-square me-1"></i> Editar</a>
                                    <button class="btn btn-sm btn-outline-danger flex-grow-1" onclick="prepararExclusaoAnimal(@animal.Id, '@animal.NomeEspecie')"><i class="bi bi-trash-fill me-1"></i> Excluir</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="col-12 col-md-6 col-lg-4 item-animal" data-tipo="add">
            <a href="/Animal/CriarAnimal" class="animal-card add-card h-100 d-flex flex-column align-items-center justify-content-center text-center p-4 text-decoration-none" style="min-height: 240px;">
                <i class="bi bi-plus-circle mb-3" style="font-size: 3rem; color: rgba(255,255,255,0.6);"></i>
                <h4 class="fw-bold text-light mb-1">Novo Animal</h4>
                <p class="opacity-75 small text-light mb-0">Criar uma configuração do zero</p>
            </a>
        </div>

    </div>
</div>

<div class="modal fade" id="modalExcluirAnimal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: rgba(22, 71, 16, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.2); color: #fff;">
            <div class="modal-header border-bottom border-secondary border-opacity-50">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i> Remover Preset</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="fs-5 mb-2">Você deseja excluir as configurações salvas de:</p>
                <h3 class="fw-bold text-warning mb-4" id="nomeAnimalAlvo">Nome do Animal</h3>
            </div>
            <div class="modal-footer border-top border-secondary border-opacity-50 justify-content-center gap-3">
                <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger px-4 shadow" onclick="confirmarExclusaoAnimal()"><i class="bi bi-trash-fill me-2"></i> Sim, Excluir Preset</button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: url('/images/FundoNidus.png') no-repeat center center fixed !important;
        background-size: cover !important;
    }

    .titulo-pagina {
        color: #164710;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.8);
        padding: 10px 20px;
        border-radius: 10px;
        display: inline-block;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .btn-filtro {
        background: rgba(0, 0, 0, 0.3);
        color: rgba(255,255,255,0.7);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 30px;
        padding: 8px 25px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

        .btn-filtro:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border-color: rgba(255,255,255,0.3);
        }

        .btn-filtro.active {
            background: #164710;
            color: #fff;
            border-color: #28a745;
            box-shadow: 0 0 15px rgba(40, 167, 69, 0.4) !important;
        }

    .item-animal {
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .animal-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 20px;
        padding: 25px;
        color: #fff;
        display: flex;
        flex-direction: column;
        transition: 0.3s;
        height: 100%;
    }

        .animal-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.12);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

    .border-padrao {
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .border-customizado {
        border: 1px solid rgba(40, 167, 69, 0.5);
        box-shadow: 0 0 15px rgba(40, 167, 69, 0.1);
    }

    .variaveis-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
        background: rgba(0,0,0,0.2);
        padding: 15px;
        border-radius: 12px;
    }

    .var-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.95rem;
        border-bottom: 1px dashed rgba(255,255,255,0.1);
        padding-bottom: 5px;
    }

        .var-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .add-card {
        border: 2px dashed rgba(255,255,255,0.3);
        background: rgba(0,0,0,0.2);
        cursor: pointer;
    }

        .add-card:hover {
            border-color: #fff;
            background: rgba(0,0,0,0.3);
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const perfilAtivo = sessionStorage.getItem("nidus_perfil");

        // LÓGICA DE PERFIL: Esconde os filtros e simulações do cliente se for Admin
        if(perfilAtivo === "admin") {
            const blocoFiltros = document.getElementById('blocoFiltros');
            if (blocoFiltros) blocoFiltros.classList.add('d-none');

            const itensCliente = document.querySelectorAll('.cliente-only');
            itensCliente.forEach(el => el.classList.add('d-none'));
        }

        // Lógica do Filtro
        const botoesFiltro = document.querySelectorAll('.btn-filtro');
        const itensAnimal = document.querySelectorAll('.item-animal');

        botoesFiltro.forEach(botao => {
            botao.addEventListener('click', function() {
                botoesFiltro.forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                const filtro = this.getAttribute('data-filtro');

                itensAnimal.forEach(item => {
                    const tipo = item.getAttribute('data-tipo');

                    if (filtro === 'todos') {
                        item.classList.remove('d-none');
                    } else if (filtro === 'padrao') {
                        if (tipo === 'padrao') item.classList.remove('d-none');
                        else item.classList.add('d-none');
                    } else if (filtro === 'customizado') {
                        if (tipo === 'customizado' || tipo === 'add') item.classList.remove('d-none');
                        else item.classList.add('d-none');
                    }
                });
            });
        });
    });

    // LÓGICA DO MODAL CONECTADA À CONTROLLER C#
    let modalAnimal;
    let animalIdParaExcluir = 0;

    function prepararExclusaoAnimal(id, nomeDoAnimal) {
        animalIdParaExcluir = id;
        document.getElementById('nomeAnimalAlvo').innerText = nomeDoAnimal;
        modalAnimal = new bootstrap.Modal(document.getElementById('modalExcluirAnimal'));
        modalAnimal.show();
    }

    function confirmarExclusaoAnimal() {
        modalAnimal.hide();
        // Dispara a rota de exclusão no back-end
        window.location.href = "/Animal/ExcluirAnimal/" + animalIdParaExcluir;
    }
</script>