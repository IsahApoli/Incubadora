@model List<NidusFront.Models.FazendaViewModel>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor Accessor
@{
    ViewData["Title"] = "Minhas Fazendas";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    // Identifica o perfil logado para aplicar as travas visuais
    string perfilLogado = Accessor.HttpContext?.Session.GetString("UsuarioPerfil") ??
                          Accessor.HttpContext?.Session.GetString("nidus_perfil") ?? "";
    bool isAdmin = perfilLogado.ToLower() == "admin";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="titulo-pagina m-0"><i class="bi bi-houses-fill me-2"></i> MINHAS FAZENDAS</h2>
    </div>

    <div class="row g-4">

        @foreach (var fazenda in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="fazenda-card-container h-100">
                    <a href="/Incubadora/Incubadoras?idFazenda=@fazenda.Id" class="fazenda-card-link">
                        <div class="fazenda-icone">
                            <i class="bi bi-house-door-fill"></i>
                        </div>
                        <h3 class="fw-bold mb-1 mt-3">@fazenda.NomeFantasia</h3>

                        <p class="location-text"><i class="bi bi-file-earmark-text-fill"></i> CNPJ: @fazenda.Cnpj</p>

                        <div class="active-count-box">
                            <span class="count-number"><i class="bi bi-egg-fill text-warning fs-5"></i></span>
                            <span class="count-label">Acessar Incubadoras</span>
                        </div>
                    </a>

                    <div class="fazenda-footer">
                        <div class="d-flex gap-2 w-100">
                            <a href="/Fazenda/EditarFazenda/@fazenda.Id" class="btn btn-sm btn-outline-warning flex-grow-1"><i class="bi bi-pencil-square me-1"></i> Editar</a>

                            @if (isAdmin)
                            {
                                <button class="btn btn-sm btn-outline-danger flex-grow-1" onclick="prepararExclusao(@fazenda.Id, '@fazenda.NomeFantasia')"><i class="bi bi-trash-fill me-1"></i> Excluir</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (isAdmin)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a href="/Fazenda/CriarFazenda" class="fazenda-card-container add-card h-100 text-decoration-none d-flex flex-column align-items-center justify-content-center text-center p-5">
                    <i class="bi bi-plus-circle mb-3" style="font-size: 3.5rem; color: rgba(255,255,255,0.6);"></i>
                    <h4 class="fw-bold text-light mb-1">Adicionar Fazenda</h4>
                    <p class="opacity-75 small text-light mb-0">Cadastrar nova unidade produtiva</p>
                </a>
            </div>
        }

    </div>
</div>

<div class="modal fade" id="modalExcluirFazenda" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: rgba(22, 71, 16, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.2); color: #fff;">
            <div class="modal-header border-bottom border-secondary border-opacity-50">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i> Atenção: Ação Irreversível</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="fs-5 mb-2">Você está prestes a excluir permanentemente:</p>
                <h3 class="fw-bold text-warning mb-4" id="nomeFazendaAlvo">Nome da Fazenda</h3>
                <div class="alert alert-danger text-start p-3 mb-0 border-0" style="background: rgba(220, 53, 69, 0.2);">
                    <i class="bi bi-info-circle-fill me-2"></i> Esta ação apagará todo o histórico, incubadoras e perfis vinculados a esta unidade.
                </div>
            </div>
            <div class="modal-footer border-top border-secondary border-opacity-50 justify-content-center gap-3">
                <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger px-4 shadow" onclick="confirmarExclusao()"><i class="bi bi-trash-fill me-2"></i> Sim, Excluir Fazenda</button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: url('/images/FundoNidus.png') no-repeat center center fixed !important;
        background-size: cover !important;
    }

    .titulo-pagina {
        color: #164710;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.8);
        padding: 10px 20px;
        border-radius: 10px;
        display: inline-block;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .fazenda-card-container {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        transition: 0.3s;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

        .fazenda-card-container:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(255, 255, 255, 0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

    .fazenda-card-link {
        padding: 30px;
        text-decoration: none;
        color: #fff !important;
        display: block;
        flex-grow: 1;
    }

    .location-text {
        font-size: 0.95rem;
        opacity: 0.8;
        margin-bottom: 20px;
    }

    .fazenda-icone {
        font-size: 2.2rem;
        color: #164710;
        background: rgba(255, 255, 255, 0.9);
        width: 65px;
        height: 65px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .active-count-box {
        background: rgba(22, 71, 16, 0.3);
        border-radius: 12px;
        padding: 10px 15px;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid rgba(255,255,255,0.1);
        margin-top: auto;
    }

    .count-number {
        font-size: 1.8rem;
        font-weight: 800;
        color: #fff;
        line-height: 1;
    }

    .count-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.9;
        line-height: 1.2;
    }

    .fazenda-footer {
        padding: 15px 30px 25px 30px;
        background: rgba(0, 0, 0, 0.15);
        margin-top: auto;
    }

    .add-card {
        border: 2px dashed rgba(255,255,255,0.3);
        background: rgba(0,0,0,0.2);
        cursor: pointer;
    }

        .add-card:hover {
            border-color: #fff;
            background: rgba(0,0,0,0.3);
        }
</style>

<script>
    // LÓGICA DO MODAL CONECTADA À CONTROLLER C#
    let modalExcluir;
    let fazendaIdParaExcluir = 0;

    function prepararExclusao(id, nomeDaFazenda) {
        fazendaIdParaExcluir = id;
        document.getElementById('nomeFazendaAlvo').innerText = nomeDaFazenda;
        modalExcluir = new bootstrap.Modal(document.getElementById('modalExcluirFazenda'));
        modalExcluir.show();
    }

    function confirmarExclusao() {
        modalExcluir.hide();
        // Dispara a rota de exclusão no back-end
        window.location.href = "/Fazenda/ExcluirFazenda/" + fazendaIdParaExcluir;
    }
</script>