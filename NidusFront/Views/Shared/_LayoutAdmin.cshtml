@using Microsoft.AspNetCore.Http
@{
    string nomeUsuario = Context.Session.GetString("UsuarioNome") ?? "Usuário";
    string perfil = Context.Session.GetString("UsuarioPerfil") ?? "Cliente";
    string fotoBase64 = Context.Session.GetString("UsuarioFoto");
    bool isAdmin = perfil.ToLower() == "admin";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NIDUS - @ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Saira:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <style>
        body {
            background: url('/images/FundoNidus.png') no-repeat center center fixed;
            background-size: cover;
            margin: 0;
            padding: 0;
            font-family: 'Saira', sans-serif;
            color: #fff;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: rgba(22, 71, 16, 0.9);
            backdrop-filter: blur(10px);
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            border-right: 2px solid rgba(255, 255, 255, 0.1);
            padding: 20px 0;
            z-index: 1000;
        }

        .sidebar-logo {
            text-align: center;
            padding-bottom: 20px;
            margin: 0 20px;
        }

            .sidebar-logo img {
                max-width: 140px;
                height: auto;
            }

        .sidebar-user-panel {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            background: rgba(0, 0, 0, 0.15);
            border-top: 1px solid rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            margin-bottom: 10px;
        }

        .sidebar-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px solid #28a745;
            background-image: url('https://cdn-icons-png.flaticon.com/512/3135/3135715.png');
            background-size: cover;
            background-position: center;
            margin-right: 12px;
            flex-shrink: 0;
        }

        .sidebar-avatar-foto {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            border: 2px solid #28a745;
            object-fit: cover;
            margin-right: 12px;
            flex-shrink: 0;
        }

        .sidebar-user-info {
            overflow: hidden;
        }

        .sidebar-user-name {
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 0;
            color: #fff;
            white-space: nowrap;
            text-overflow: ellipsis;
            overflow: hidden;
        }

        .sidebar-user-role {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0;
        }

        .sidebar-menu {
            list-style: none;
            padding: 10px 0;
            margin: 0;
            flex-grow: 1;
        }

            .sidebar-menu li a {
                display: flex;
                align-items: center;
                padding: 12px 25px;
                color: rgba(255, 255, 255, 0.8);
                text-decoration: none;
                font-weight: 500;
                transition: 0.3s;
            }

                .sidebar-menu li a i {
                    font-size: 1.3rem;
                    margin-right: 15px;
                }

                .sidebar-menu li a:hover {
                    background: rgba(255, 255, 255, 0.1);
                    color: #fff;
                    padding-left: 30px;
                }

        .main-content {
            margin-left: 260px;
            padding: 40px;
            min-height: 100vh;
        }
    </style>
</head>
<body>

    <nav class="sidebar">
        <div class="sidebar-logo">
            <img src="~/images/LogoNidus.png" alt="NIDUS Logo">
        </div>

        <div class="sidebar-user-panel">
            @if (!string.IsNullOrEmpty(fotoBase64))
            {
                <img src="data:image/jpeg;base64,@fotoBase64" class="sidebar-avatar-foto" />
            }
            else
            {
                <div class="sidebar-avatar"></div>
            }
            <div class="sidebar-user-info">
                <p class="sidebar-user-name">@nomeUsuario</p>
                <p class="sidebar-user-role @(isAdmin ? "text-warning" : "text-success")">
                    @(isAdmin ? "Administrador" : "Cliente")
                </p>
            </div>
        </div>

        <ul class="sidebar-menu">
            <li><a href="/Fazenda/Fazendas"><i class="bi bi-houses-fill"></i> Início (Fazendas)</a></li>

            @if (isAdmin)
            {
                <li>
                    <a href="/Usuario/Logins"><i class="bi bi-people-fill"></i> Gerenciar Logins</a>
                </li>
            }

            <li><a href="/Animal/Animais"><i class="bi bi-clipboard2-data-fill"></i> Editar Animais</a></li>
            <li><a href="/Usuario/EditarPerfil"><i class="bi bi-person-bounding-box"></i> Editar Perfil</a></li>
            <li><a href="/Home/Privacy"><i class="bi bi-info-circle-fill"></i> Sobre o Sistema</a></li>
        </ul>

        <div class="px-4">
            <a href="/Home/Logout" class="btn btn-outline-light w-100 border-0 text-start"><i class="bi bi-box-arrow-right me-2"></i> Sair</a>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index: 2000;">
        <div id="toastSucesso" class="toast align-items-center border-0" style="background: rgba(40, 167, 69, 0.95); backdrop-filter: blur(10px); color: #fff;" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-bold fs-6" id="toastMensagem">
                    <i class="bi bi-check-circle-fill me-2"></i> Operação realizada com sucesso!
                </div>
                <button type="button" class="btn-close btn-close-white me-3 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function simularSalvar(event, mensagem, urlDestino) {
            event.preventDefault();
            document.getElementById('toastMensagem').innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> ' + mensagem;
            const toastEl = document.getElementById('toastSucesso');
            const toast = new bootstrap.Toast(toastEl, { delay: 2000 });
            toast.show();
            setTimeout(() => {
                window.location.href = urlDestino;
            }, 1500);
        }
    </script>

</body>
</html>