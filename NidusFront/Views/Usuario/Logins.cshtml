@model List<NidusFront.Models.UsuarioViewModel>
@{
    ViewData["Title"] = "Gestão de Logins";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="titulo-pagina m-0"><i class="bi bi-people-fill me-2"></i> GESTÃO DE ACESSOS</h2>
    </div>

    <p class="text-white opacity-75 mb-4">Administre os logins dos clientes. Cada acesso é filtrado pelo CNPJ da fazenda.</p>

    <div class="row g-4">

        @foreach (var user in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="login-card h-100">
                    <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom border-secondary border-opacity-50">
                        <div class="login-icone bg-success text-white flex-shrink-0">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div style="overflow: hidden;">
                            <h4 class="fw-bold mb-0 text-white text-truncate">@user.Nome</h4>
                            <p class="text-light opacity-75 small mb-0 text-truncate">@user.Email</p>
                        </div>
                    </div>

                    <div class="mb-4">
                        <p class="small text-warning fw-bold mb-1"><i class="bi bi-link-45deg"></i> CNPJ / Perfil Vinculado</p>
                        <p class="text-white fs-5 font-monospace mb-0">@(string.IsNullOrEmpty(user.Cnpj) ? user.Perfil : user.Cnpj)</p>
                    </div>

                    <div class="mt-auto">
                        <div class="d-flex gap-2">
                            <a href="/Usuario/EditarLogin/@user.Id" class="btn btn-sm btn-outline-warning flex-grow-1"><i class="bi bi-pencil-square me-1"></i> Editar</a>
                            <button class="btn btn-sm btn-outline-danger flex-grow-1" onclick="prepararExclusaoLogin(@user.Id, '@user.Nome')"><i class="bi bi-trash-fill me-1"></i> Excluir</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="col-12 col-md-6 col-lg-4">
            <a href="/Usuario/CriarLogin" class="login-card add-card h-100 d-flex flex-column align-items-center justify-content-center text-center p-4 text-decoration-none" style="min-height: 240px;">
                <i class="bi bi-person-plus-fill mb-3" style="font-size: 3rem; color: rgba(255,255,255,0.6);"></i>
                <h4 class="fw-bold text-light mb-1">Novo Acesso</h4>
                <p class="opacity-75 small text-light mb-0">Cadastrar conta de cliente</p>
            </a>
        </div>

    </div>
</div>

<div class="modal fade" id="modalExcluirLogin" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: rgba(22, 71, 16, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.2); color: #fff;">
            <div class="modal-header border-bottom border-secondary border-opacity-50">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i> Revogar Acesso</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="fs-5 mb-2">Você deseja apagar a conta e o acesso do cliente:</p>
                <h3 class="fw-bold text-warning mb-4" id="nomeLoginAlvo">Nome do Cliente</h3>
                <div class="alert alert-danger text-start p-3 mb-0 border-0" style="background: rgba(220, 53, 69, 0.2);">
                    <i class="bi bi-info-circle-fill me-2"></i> O cliente perderá acesso ao painel imediatamente. Os dados das fazendas permanecerão no banco.
                </div>
            </div>
            <div class="modal-footer border-top border-secondary border-opacity-50 justify-content-center gap-3">
                <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger px-4 shadow" onclick="confirmarExclusaoLogin()"><i class="bi bi-trash-fill me-2"></i> Excluir Login</button>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: url('/images/FundoNidus.png') no-repeat center center fixed !important;
        background-size: cover !important;
    }

    .titulo-pagina {
        color: #164710;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.8);
        padding: 10px 20px;
        border-radius: 10px;
        display: inline-block;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    .login-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        padding: 25px;
        color: #fff;
        display: flex;
        flex-direction: column;
        transition: 0.3s;
    }

        .login-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.12);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

    .login-icone {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .add-card {
        border: 2px dashed rgba(255,255,255,0.3);
        background: rgba(0,0,0,0.2);
        cursor: pointer;
    }

        .add-card:hover {
            border-color: #fff;
            background: rgba(0,0,0,0.3);
        }
</style>

<script>
    let modalLogin;
    let idLoginExcluir = 0;

    function prepararExclusaoLogin(id, nomeDoCliente) {
        idLoginExcluir = id;
        document.getElementById('nomeLoginAlvo').innerText = nomeDoCliente;
        modalLogin = new bootstrap.Modal(document.getElementById('modalExcluirLogin'));
        modalLogin.show();
    }

    // ROTA CONECTADA AO BACK-END
    function confirmarExclusaoLogin() {
        modalLogin.hide();
        window.location.href = "/Usuario/ExcluirLogin/" + idLoginExcluir;
    }
</script>